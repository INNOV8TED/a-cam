window.toggleGcpConfig = function(e) { Antigravity.toggleGcpConfig(e); };
window.pushToProduction = function() { Antigravity.pushToProduction(); };

window.analyzeBackgroundVision = async function(b64) {
    const key = document.getElementById('acam_gemini_key')?.value || localStorage.getItem('acam_gemini_key');
    // Using stable Gemini 1.5 Flash
    const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${key}`;
    try {
        const payload = { contents: [{ parts: [{ text: "Analyze background. JSON: description, foreground, midground, background." }, { inlineData: { mimeType: "image/jpeg", data: b64.split(',')[1] } }] }] };
        const res = await fetchWithProxy(url, { method: 'POST', body: JSON.stringify(payload) });
        const data = await res.json();
        const text = data.candidates[0].content.parts[0].text;
        return JSON.parse(text.replace(/```json|```/g, '').trim());
    } catch (e) { return null; }
};

window.analyzeImageVertexAI = async function(b64) { 
    const key = document.getElementById('acam_gemini_key')?.value || localStorage.getItem('acam_gemini_key');
    const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${key}`;
    try {
        const payload = { contents: [{ parts: [{ text: "Analyze character outfit. JSON: outfit, description." }, { inlineData: { mimeType: "image/jpeg", data: b64.split(',')[1] } }] }] };
        const res = await fetchWithProxy(url, { method: 'POST', body: JSON.stringify(payload) });
        const data = await res.json();
        const text = data.candidates[0].content.parts[0].text;
        return JSON.parse(text.replace(/```json|```/g, '').trim());
    } catch (e) { return { outfit: "Cinematic attire.", description: "Subject in atmosphere." }; }
};